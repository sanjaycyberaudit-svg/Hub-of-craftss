{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Cloudflare Pages project (Git builds).
  // Do NOT set assets.binding = "ASSETS" here — that name is reserved on Pages.
  // Pages injects ASSETS automatically for `_worker.js` in the output directory.
  "name": "hub-of-craftss",
  "pages_build_output_dir": ".open-next/pages",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"]
}
